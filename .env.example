GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://your-service.run.app"

# GOOGLE_CLIENT_ID: Required for Google Sign-In (Google Identity Services).
# Create at: https://console.cloud.google.com/apis/credentials
# Type: OAuth 2.0 Client ID (Web application)
# Authorized JavaScript Origins: http://localhost:8080, https://your-service.run.app
GOOGLE_CLIENT_ID="your-google-client-id"

# GOOGLE_CLIENT_SECRET: Required for Calendar API OAuth code exchange.
# Found in the same OAuth 2.0 Client ID entry in Google Cloud Console.
# NEVER commit this value to version control.
GOOGLE_CLIENT_SECRET="your-google-client-secret"
